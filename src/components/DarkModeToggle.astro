---
---

<mode-toggle>
  <button
    class="unset ml-4 rounded-sm transition-colors duration-150 ease-in-out hover:text-candy-pink"
    id="mode-toggle"
    tabindex="0"
    role="switch"
    aria-checked="false"
    title="Toggle dark mode"
  >
    <span class="sr-only">Toggle dark mode</span>
    <span id="mode-icon"></span>
  </button>
</mode-toggle>

<script>
  function updateHTMLTheme(mode: "light" | "dark") {
    const themeColorMetaTag = document.head.querySelector(
      'meta[name="theme-color"]'
    );
    if (mode === "dark") {
      document.documentElement.classList.remove("light");
      document.documentElement.classList.add("dark");
      if (themeColorMetaTag) {
        (themeColorMetaTag as HTMLMetaElement).content = "#0f172a";
      }
    } else {
      document.documentElement.classList.remove("dark");
      document.documentElement.classList.add("light");
      if (themeColorMetaTag) {
        (themeColorMetaTag as HTMLMetaElement).content = "#ffffff";
      }
    }
  }
  function updateStorageTheme(mode: "light" | "dark") {
    sessionStorage.setItem("theme", mode);
  }
  class ModeToggle extends HTMLElement {
    constructor() {
      super();
      let currentMode: "light" | "dark" =
        document.documentElement.classList.contains("dark") ? "dark" : "light";
      const toggle = this.querySelector("button");
      const iconContainer = this.querySelector("#mode-icon");

      const sunIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`;

      const moonIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>`;

      const updateIcon = (mode: "light" | "dark") => {
        if (iconContainer) {
          iconContainer.innerHTML = mode === "dark" ? sunIcon : moonIcon;
        }
      };

      if (toggle) {
        toggle.setAttribute(
          "aria-checked",
          currentMode === "dark" ? "true" : "false"
        );
      }

      updateIcon(currentMode);

      toggle?.addEventListener("click", () => {
        if (currentMode === "dark") {
          const modeToSwitch = "light";
          updateHTMLTheme(modeToSwitch);
          updateStorageTheme(modeToSwitch);
          updateIcon(modeToSwitch);
          currentMode = modeToSwitch;
          toggle?.setAttribute("aria-checked", "false");
        } else {
          const modeToSwitch = "dark";
          updateHTMLTheme(modeToSwitch);
          updateStorageTheme(modeToSwitch);
          updateIcon(modeToSwitch);
          currentMode = modeToSwitch;
          toggle?.setAttribute("aria-checked", "true");
        }
      });
    }
  }

  customElements.define("mode-toggle", ModeToggle);
</script>
